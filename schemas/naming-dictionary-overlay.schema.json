{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beamkit.dev/schemas/naming-dictionary-overlay.schema.json",
  "title": "BeamKit structure-name dictionary overlay",
  "type": "object",
  "additionalProperties": false,
  "required": [ "id" ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "baseDictionaryId": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "tagsToAdd": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "canonicalNamesToAdd": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "aliasesToAdd": {
      "type": "array",
      "items": { "$ref": "#/$defs/alias" },
      "default": []
    },
    "regexMappingsToAdd": {
      "type": "array",
      "items": { "$ref": "#/$defs/regexMapping" },
      "default": []
    },
    "requiredStructureNamesToAdd": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "requiredStructureNamesToRemove": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "deprecatedNamesToAdd": {
      "type": "array",
      "items": { "$ref": "#/$defs/deprecatedName" },
      "default": []
    }
  },
  "$defs": {
    "alias": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "alias", "canonicalName" ],
      "properties": {
        "alias": { "type": "string", "minLength": 1 },
        "canonicalName": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 }
      }
    },
    "regexMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "pattern", "canonicalName" ],
      "properties": {
        "pattern": { "type": "string", "minLength": 1 },
        "canonicalName": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 }
      }
    },
    "deprecatedName": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "name", "canonicalName" ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "canonicalName": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 }
      }
    }
  }
}
