{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beamkit.dev/schemas/rtpx-0.1.schema.json",
  "title": "RT-PX v0.1 Radiotherapy Protocol Exchange Package",
  "description": "Portable treatment intent, validation constraints, workflow requirements, and source traceability for radiation oncology research protocols and local clinical protocols.",
  "type": "object",
  "required": [
    "id",
    "schemaVersion",
    "name",
    "version",
    "diseaseSite",
    "intent",
    "status",
    "structures",
    "prescriptions"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "0.1",
      "description": "RT-PX schema version."
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "diseaseSite": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "Draft",
        "InReview",
        "Approved",
        "Retired"
      ]
    },
    "owner": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "sourceDocument": {
      "type": "object",
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "hash": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "approval": {
      "type": "object",
      "properties": {
        "reviewedBy": {
          "type": "string"
        },
        "approvedBy": {
          "type": "string"
        },
        "effectiveDate": {
          "type": "string",
          "format": "date"
        },
        "reviewDueDate": {
          "type": "string",
          "format": "date"
        },
        "reference": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "changeTicket": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "structures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/structure"
      }
    },
    "prescriptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/prescription"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/constraint"
      }
    },
    "planChecks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/planCheck"
      }
    },
    "workflow": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflow"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "requirementLevel": {
      "enum": [
        "Informational",
        "Recommended",
        "Required"
      ]
    },
    "source": {
      "type": "object",
      "properties": {
        "section": {
          "type": "string"
        },
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "anchor": {
          "type": "string"
        },
        "quote": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "structure": {
      "type": "object",
      "required": [
        "id",
        "name",
        "role"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "role": {
          "enum": [
            "Target",
            "OrganAtRisk",
            "External",
            "PlanningHelper",
            "Other"
          ]
        },
        "level": {
          "$ref": "#/$defs/requirementLevel"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mustHaveContours": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/source"
        }
      },
      "additionalProperties": false
    },
    "prescription": {
      "type": "object",
      "required": [
        "id",
        "target",
        "totalDoseGy",
        "fractionCount"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "totalDoseGy": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "fractionCount": {
          "type": "integer",
          "minimum": 1
        },
        "dosePerFractionGy": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "technique": {
          "type": "string"
        },
        "energy": {
          "type": "string"
        },
        "level": {
          "$ref": "#/$defs/requirementLevel"
        },
        "description": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/source"
        }
      },
      "additionalProperties": false
    },
    "constraint": {
      "type": "object",
      "required": [
        "id",
        "structure",
        "metric",
        "comparison",
        "value",
        "unit"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "structure": {
          "type": "string"
        },
        "metric": {
          "type": "string",
          "description": "Metric expression such as Max, Mean, D95%, V20Gy, CI, HI, GI, or R50."
        },
        "comparison": {
          "enum": [
            "LessThan",
            "LessThanOrEqual",
            "GreaterThan",
            "GreaterThanOrEqual",
            "Equal"
          ]
        },
        "value": {
          "type": "number",
          "minimum": 0
        },
        "unit": {
          "type": "string"
        },
        "level": {
          "$ref": "#/$defs/requirementLevel"
        },
        "description": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "isActive": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "planCheck": {
      "type": "object",
      "required": [
        "id",
        "title",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "level": {
          "$ref": "#/$defs/requirementLevel"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "isActive": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "workflow": {
      "type": "object",
      "required": [
        "id",
        "title",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "level": {
          "$ref": "#/$defs/requirementLevel"
        },
        "description": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "isActive": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  }
}
