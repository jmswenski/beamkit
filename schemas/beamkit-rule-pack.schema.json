{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beamkit.dev/schemas/beamkit-rule-pack.schema.json",
  "title": "BeamKit Rule Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [ "name", "version", "clinicalRuleCatalog", "planCheckCatalog" ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "diseaseSite": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "clinicalRuleCatalog": {
      "type": "string",
      "minLength": 1,
      "description": "Path to a BeamKit clinical rule catalog JSON file, relative to this manifest."
    },
    "planCheckCatalog": {
      "type": "string",
      "minLength": 1,
      "description": "Path to a BeamKit plan-check catalog JSON file, relative to this manifest."
    },
    "namingDictionary": {
      "type": "string",
      "description": "Optional path to a BeamKit naming dictionary JSON file, relative to this manifest."
    },
    "machineProfile": {
      "type": "string",
      "description": "Optional path to a BeamKit machine profile JSON file, relative to this manifest."
    },
    "clinicalRuleQuery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "diseaseSite": { "type": "string" },
        "institution": { "type": "string" },
        "physician": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "readinessDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ctImported": { "type": "boolean" },
        "optimizationFinished": { "type": "boolean" },
        "physicsQaComplete": { "type": "boolean" },
        "physicianApprovalComplete": { "type": "boolean" },
        "treatmentReady": { "type": "boolean" }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional governance metadata for rule-pack review, approval, and periodic re-review.",
      "properties": {
        "status": {
          "type": "string",
          "description": "Governance state, for example Draft, InReview, Approved, or Retired."
        },
        "institution": {
          "type": "string"
        },
        "physicianGroup": {
          "type": "string"
        },
        "reviewedBy": {
          "type": "string"
        },
        "approvedBy": {
          "type": "string"
        },
        "effectiveDate": {
          "type": "string",
          "format": "date"
        },
        "reviewDueDate": {
          "type": "string",
          "format": "date"
        },
        "reference": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "changeTicket": {
          "type": "string"
        }
      }
    }
  }
}
