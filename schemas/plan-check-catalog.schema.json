{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beamkit.dev/schemas/plan-check-catalog.schema.json",
  "title": "BeamKit plan-check catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [ "name", "version", "checks" ],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/check" }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "id", "title", "type" ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": [
            "dose-exists",
            "beams-present",
            "structure-exists",
            "structure-not-empty",
            "dose-grid-max-spacing",
            "prescription-energy",
            "prescription-technique",
            "prescription-fractionation",
            "calculation-model",
            "beam-model",
            "dose-metric",
            "target-coverage",
            "plan-quality-metric",
            "deliverability"
          ]
        },
        "severity": { "type": "string", "enum": [ "Info", "Warning", "Failure" ] },
        "description": { "type": "string", "minLength": 1 },
        "reference": { "type": "string", "minLength": 1 },
        "requirementId": { "type": "string", "minLength": 1 },
        "hazardIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "controlIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "isActive": { "type": "boolean" },
        "parameters": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
