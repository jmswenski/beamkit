{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beamkit.dev/schemas/staff-roster.schema.json",
  "title": "BeamKit staff roster",
  "type": "object",
  "additionalProperties": false,
  "required": [ "name", "staff" ],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "staff": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/staffMember" }
    }
  },
  "$defs": {
    "staffMember": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "id", "displayName" ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "enum": [ "Dosimetrist", "Physicist" ] },
        "skills": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "preferredDiseaseSites": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "activeCaseCount": { "type": "integer", "minimum": 0 },
        "maxActiveCaseCount": { "type": "integer", "minimum": 1 },
        "maxComplexityScore": { "type": "integer", "minimum": 1, "maximum": 5 },
        "ptoUntil": { "type": "string", "format": "date" },
        "preferredPhysicians": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "blockedPhysicians": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "schedule": {
          "type": "array",
          "items": { "$ref": "#/$defs/scheduleDay" }
        },
        "unavailableDateRanges": {
          "type": "array",
          "items": { "$ref": "#/$defs/unavailableDateRange" }
        }
      }
    },
    "scheduleDay": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "date" ],
      "properties": {
        "date": { "type": "string", "format": "date" },
        "assignedCaseCount": { "type": "integer", "minimum": 0 },
        "capacity": { "type": "integer", "minimum": 0 },
        "isUnavailable": { "type": "boolean" },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "unavailableDateRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "startDate", "endDate" ],
      "properties": {
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "note": { "type": "string", "minLength": 1 }
      }
    }
  }
}
