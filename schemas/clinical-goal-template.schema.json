{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beamkit.dev/schemas/clinical-goal-template.schema.json",
  "title": "BeamKit clinical goal template set",
  "type": "object",
  "additionalProperties": false,
  "required": [ "name", "goals" ],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "diseaseSite": { "type": "string", "minLength": 1 },
    "institution": { "type": "string", "minLength": 1 },
    "physician": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "approvedBy": { "type": "string", "minLength": 1 },
    "approvedOn": { "type": "string", "minLength": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "goals": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/goal" }
    }
  },
  "$defs": {
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "id", "structureName", "metricKey", "comparison", "threshold", "unit" ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "structureName": { "type": "string", "minLength": 1 },
        "metricKey": { "type": "string", "minLength": 1 },
        "comparison": {
          "type": "string",
          "enum": [ "LessThan", "LessThanOrEqual", "GreaterThan", "GreaterThanOrEqual", "Equal" ]
        },
        "threshold": { "type": "number" },
        "unit": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": [ "Advisory", "Warning", "Required" ],
          "default": "Required"
        },
        "description": { "type": "string", "minLength": 1 },
        "reference": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "requirementId": { "type": "string", "minLength": 1 },
        "hazardIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "controlIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "isActive": { "type": "boolean", "default": true }
      }
    }
  }
}
