          "threshold": 45,
          "unit": "Gy",
          "severity": "Required",
          "description": "Spinal cord maximum dose limit.",
          "reference": "Synthetic institutional head-and-neck baseline",
          "rationale": "Captures a required serial-organ constraint for automated QA.",
          "tags": [ "oar", "cord", "head-neck" ]
        },
        {
